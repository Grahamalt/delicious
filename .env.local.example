# LLM Provider: "claude" or "openai"
LLM_PROVIDER=claude

# Claude API Key (from console.anthropic.com) — needed if LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API Key (from platform.openai.com) — needed if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o

# Google Sheets
GOOGLE_SHEET_ID=your-spreadsheet-id-here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Simple password to protect the app
APP_PASSWORD=your-secret-password
